# K-SNS dedicated UI environment
# Copy to .env.local for local development. Never commit real values.

# Browser-facing app origin for redirects and deployment checks.
NEXT_PUBLIC_APP_ORIGIN=https://sns.kariya.ca

# Same-origin K-SNS UI API facade. Browser code must use this relative path.
NEXT_PUBLIC_SNS_API_BASE=/platform/c009

# Optional C-009 staging verification inputs.
# Do not commit a live session cookie.
KARIYA_SNS_UI_C009_ORIGIN=https://sns.kariya.ca
KARIYA_SNS_UI_C009_ENDPOINTS=
KARIYA_SNS_UI_C009_SESSION_COOKIE=

# Optional server-side upstream origin for future BFF/API route work only.
# Do not prefix with NEXT_PUBLIC_ and do not expose internal URLs to the browser.
K_SNS_UPSTREAM_ORIGIN=

# Next.js telemetry
NEXT_TELEMETRY_DISABLED=1
