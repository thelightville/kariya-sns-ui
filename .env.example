# Kariya K-SNS UI — environment variables
# Copy to .env.local (development) or inject via CI/CD (production)
# Never commit real values

# ── K-SNS platform API ──────────────────────────────────────────────────────

# K-SNS C-009 external API base URL, consumed directly by
# src/lib/ksnsPlatformClient.ts (public — used by the browser).
# Example (dev):        http://localhost:8000/api/v1
# Example (production): https://ksns-api.kariya.internal/api/v1
NEXT_PUBLIC_KSNS_API_URL=http://localhost:8000/api/v1

# Public app domain — used for cookie scoping and absolute-URL generation.
# Both sns.kariya.ca and sns.kariya.ng route to the same CT119 origin
# (see ADR-0019); this value identifies the domain the app is currently
# served from.
NEXT_PUBLIC_APP_DOMAIN=sns.kariya.ng

# ── Next.js ──────────────────────────────────────────────────────────────────

# Next.js telemetry — set to 1 to disable
NEXT_TELEMETRY_DISABLED=1
