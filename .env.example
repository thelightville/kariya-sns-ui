# Kariya K-SNS UI — environment variables
# Copy to .env.local (development) or inject via CI/CD (production)
# Never commit real values or browser-exposed secrets.

# ── K-SNS platform API ──────────────────────────────────────────────────────

# K-SNS C-009/API base URL, consumed only by the same-origin /api/ksns BFF.
# This must stay server-side. Do not expose the internal K-SNS URL as NEXT_PUBLIC_*.
K_SNS_BASE_URL=http://localhost:8000/api/v1

# Optional server-side tenant header forwarded by the /api/ksns BFF.
K_SNS_TENANT_ID=

# Tenant-scoped module routes such as /actions, /connectors, and /soc/metrics
# require a tenant id. Leave unset to show an honest unavailable state.
NEXT_PUBLIC_KSNS_TENANT_ID=

# Operator id used only for approval/request payloads where the backend requires it.
# Do not put credentials or secrets here.
NEXT_PUBLIC_KSNS_OPERATOR_ID=sns-ui-alpha1

# Public app domain — K-SNS dedicated SOC surface if retained.
# Keep the .ca and .ng treatment paired in deployment/DNS docs:
#   sns.kariya.ca
#   sns.kariya.ng
NEXT_PUBLIC_APP_DOMAIN=sns.kariya.ca

# Canonical Console portals that deep-link to K-SNS product areas:
#   console.kariya.ca
#   console.kariya.ng


# Server-side Cloud auth base URL used by /api/auth/login and /api/auth/mfa.
# Keep this server-only. Do not expose it as NEXT_PUBLIC_*.
KARIYA_CLOUD_AUTH_BASE_URL=

# Protected canonical origin used only for server-side auth redirects.
# Production accepts exactly https://sns.kariya.ng or https://sns.kariya.ca.
# It is never derived from Host or forwarded request headers.
KARIYA_SNS_PUBLIC_ORIGIN=

# Local evidence only: permits an explicit http://127.0.0.1:<port> origin.
# Never enable this flag in an sns.* deployment.
KARIYA_SNS_ALLOW_LOOPBACK_ORIGIN=0

# ── Next.js ──────────────────────────────────────────────────────────────────

# Next.js telemetry — set to 1 to disable
NEXT_TELEMETRY_DISABLED=1
